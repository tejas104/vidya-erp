{
  "openapi": "3.0.3",
  "info": {
    "title": "Vidya API",
    "version": "0.1.0",
    "description": "On-premise College Information & Analytics System. All routes are versioned under /api/v1. The bare /health, /ready and /metrics paths are rewrites of the system module's routes."
  },
  "servers": [
    {
      "url": "/"
    }
  ],
  "components": {
    "securitySchemes": {
      "sessionAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "vidya_session",
        "description": "Redis-backed session (contract defined in Vidya #1, implemented in Vidya #2). Until then, authenticated routes always return 401."
      }
    },
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/api/v1/system/health": {
      "get": {
        "summary": "Liveness probe",
        "description": "Reports that the process is up and able to serve requests. Also reachable at the conventional alias /health (Next.js rewrite).\n\n**Public route** (no authentication): liveness probes run before any credential exists; exposes no tenant data",
        "tags": [
          "system"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Process is alive",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ok"
                      ]
                    },
                    "uptimeSeconds": {
                      "type": "number"
                    },
                    "version": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "status",
                    "uptimeSeconds",
                    "version"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/system/ready": {
      "get": {
        "summary": "Readiness probe",
        "description": "Verifies Postgres and Redis are reachable and that the replica is not draining. Alias: /ready.\n\n**Public route** (no authentication): readiness probes run before any credential exists; exposes dependency names and boolean state only",
        "tags": [
          "system"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Replica is ready for traffic",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ready",
                        "unready",
                        "draining"
                      ]
                    },
                    "checks": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "ok": {
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "name",
                          "ok"
                        ]
                      }
                    }
                  },
                  "required": [
                    "status",
                    "checks"
                  ]
                }
              }
            }
          },
          "503": {
            "description": "Replica is unready or draining",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "type": "string",
                      "enum": [
                        "ready",
                        "unready",
                        "draining"
                      ]
                    },
                    "checks": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "ok": {
                            "type": "boolean"
                          }
                        },
                        "required": [
                          "name",
                          "ok"
                        ]
                      }
                    }
                  },
                  "required": [
                    "status",
                    "checks"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/system/metrics": {
      "get": {
        "summary": "Prometheus metrics",
        "description": "Prometheus text exposition for this replica. Alias: /metrics. Must be network-restricted to the scrape network in production (docs/threat-model.md).\n\n**Public route** (no authentication): scraped by Prometheus without credentials in this phase; restrict at the network layer",
        "tags": [
          "system"
        ],
        "security": [],
        "responses": {
          "200": {
            "description": "Prometheus text exposition (version 0.0.4)",
            "content": {
              "text/plain; version=0.0.4; charset=utf-8": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
