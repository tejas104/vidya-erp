# ============================================================================
# Vidya — environment template.
# Copy to .env for local development. Every value below is a LOCAL-DEV-ONLY
# default that matches docker-compose.yml. Production values are injected by
# the deployment environment (secret manager / orchestrator) and MUST never
# be committed. See docs/security-review.md#secrets.
# ============================================================================

NODE_ENV=development
LOG_LEVEL=debug

# --- PostgreSQL -------------------------------------------------------------
DATABASE_URL=postgres://vidya:local-dev-only-pg@localhost:5432/vidya
DATABASE_POOL_MAX=10

# --- Redis ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO locally, any S3-compatible store in production) --
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=local-dev-only-minio
S3_SECRET_ACCESS_KEY=local-dev-only-minio-secret
S3_BUCKET=vidya
S3_FORCE_PATH_STYLE=true

# --- Web process ------------------------------------------------------------
PORT=3000

# --- HTTP guards (Vidya #2) ---------------------------------------------------
# Comma-separated bare origins allowed to make state-changing requests in
# addition to the app's own origin (CSRF layer 2). Empty = own origin only.
TRUSTED_ORIGINS=
BODY_MAX_BYTES=1048576

# --- Identity & sessions (Vidya #2) -------------------------------------------
SESSION_COOKIE_NAME=vidya_session
# Local dev runs plain http; production MUST keep this true.
SESSION_COOKIE_SECURE=false
SESSION_TTL_HOURS=12
SESSION_IDLE_MINUTES=30
RESET_TOKEN_TTL_MINUTES=30
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MINUTES=15

# --- Analytics (Vidya #5) ----------------------------------------------------
# Aggregates over fewer distinct students are withheld (small-N leakage guard).
ANALYTICS_MIN_COHORT=5
ANALYTICS_ATTENDANCE_THRESHOLD=75
ANALYTICS_MARKS_THRESHOLD=40

# --- Demo data seeder (Vidya #6) ---------------------------------------------
# scripts/seed-demo.ts builds a self-contained DEMO college through the real
# scoped, audited chain. It is OFF unless this is exactly "true", and refuses
# under NODE_ENV=production. Non-production / evaluation only — it creates
# accounts with well-known passwords. See docs/getting-started.md.
VIDYA_ALLOW_DEMO_SEED=false

# --- Worker process ---------------------------------------------------------
WORKER_METRICS_PORT=9464
SYSTEM_HEARTBEAT_INTERVAL_MS=300000

# --- Lifecycle --------------------------------------------------------------
# How long a replica keeps serving after SIGTERM while load balancers drain it
# (readiness flips to 503 immediately; see docs/runbook.md#graceful-shutdown).
SHUTDOWN_DRAIN_MS=5000
SHUTDOWN_TIMEOUT_MS=15000
