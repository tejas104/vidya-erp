{
  "name": "vidya",
  "version": "0.1.0",
  "private": true,
  "description": "Project Vidya â€” on-premise College Information & Analytics System (modular monolith foundation)",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @vidya/web dev",
    "dev:worker": "pnpm --filter @vidya/worker dev",
    "build": "pnpm --filter @vidya/web build",
    "start": "pnpm --filter @vidya/web start",
    "worker": "pnpm --filter @vidya/worker start",
    "typecheck": "pnpm -r typecheck && tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run --project unit",
    "test:coverage": "vitest run --project unit --coverage",
    "test:integration": "vitest run --project integration --no-file-parallelism",
    "test:ui": "vitest run --project ui",
    "db:migrate": "tsx scripts/migrate.ts up",
    "db:rollback": "tsx scripts/migrate.ts down --steps 1",
    "db:status": "tsx scripts/migrate.ts status",
    "openapi:generate": "tsx scripts/generate-openapi.ts",
    "openapi:check": "tsx scripts/generate-openapi.ts --check",
    "seed:demo": "tsx scripts/seed-demo.ts",
    "check:todos": "tsx scripts/check-todos.ts",
    "check:ownership": "tsx scripts/check-table-ownership.ts",
    "compose:up": "docker compose up --build -d",
    "compose:down": "docker compose down"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "@eslint/js": "^9.30.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "@vidya/module-academics": "workspace:*",
    "@vidya/module-analytics": "workspace:*",
    "@vidya/module-identity": "workspace:*",
    "@vidya/module-people": "workspace:*",
    "@vidya/module-reporting": "workspace:*",
    "@vidya/module-portal": "workspace:*",
    "@vidya/module-timetable": "workspace:*",
    "@vidya/module-coursework": "workspace:*",
    "@vidya/module-fees": "workspace:*",
    "@vidya/module-notices": "workspace:*",
    "@vidya/module-results": "workspace:*",
    "@vidya/module-exams": "workspace:*",
    "@vidya/module-leave": "workspace:*",
    "@vidya/module-system": "workspace:*",
    "@vidya/platform": "workspace:*",
    "@vitest/coverage-v8": "^3.2.0",
    "eslint": "^9.30.0",
    "eslint-import-resolver-typescript": "^4.4.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "jsdom": "^25.0.1",
    "pg": "^8.16.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.0",
    "vitest": "^3.2.0",
    "zod": "^3.25.0"
  }
}
